\n  (def! seed (. shape :getSeed))\n  (def! g 10)\n  (def! lw (* w 0.15))\n  (def! lh (* h 0.15))\n  (def! island (. shape :getPropertyValue \"Island\"))\n  (def! landscape (< h w))\n  (. canvas :strokeRoundRect l t r b 44)\n  (. canvas :strokeRoundRect (- l g) (- t g) (+ r g) (+ b g) 50)\n  (if island\n    (if landscape\n      (. canvas :strokeRoundRect\n         (+ l g) (- y lh) (+ l (* g 3)) (+ y lh) g)\n      (. canvas :strokeRoundRect\n         (- x lw) (+ t g) (+ x lw) (+ t (* g 3)) g))))"},{"id":"viewport","script":"(do\n  (def! l (. shape :left))\n  (def! r (. shape :right))\n  (def! t (. shape :top))\n  (def! b (. shape :bottom))\n  (def! g 10)\n  [[(- l g) (- t g)] [(+ r g) (+ b g)]])"}],"corners":[42,42,42,42],"textEditable":false}],"name":"Empty","enable":false,"pageOrigin":[168,63]}]}