))\n  (def! g 10)\n  [[(- l g) (- t g)] [(+ r g) (+ b g)]])"}],"corners":[42,42,42,42],"textEditable":false}],"name":"Register","enable":false,"pageOrigin":[255.79363638664233,391.32567196511127],"pageScale":0.9742759383328421}]}